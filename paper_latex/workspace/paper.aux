\newlabel{sec:results}{{5}{6}{Results}{section.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}IoD Distributions Confirm Structural Signal with Inverted Directionality}{6}{subsection.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Median feature values by pair class on the splice-based 900-pair Wikipedia benchmark (300 pairs each class). Edit span frac captures the fraction of the aligned sequence between the first and last edit token.}}{6}{table.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Classification Results}{6}{subsection.5.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces ROC-AUC (mean $\pm $ std, 5-fold CV) on the hard subset (near-duplicate vs.\ hard-negative only) for both benchmarks. Jaccard achieves AUC = 1.000 on both datasets; inverted ECS achieves AUC $\approx $ 0.81 standalone; combining features does not improve over Jaccard alone.}}{7}{table.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ROC-AUC on the near-duplicate vs.\ hard-negative hard subset (5-fold CV) for five classifier variants on both benchmarks. Jaccard (5-gram and 2-gram) achieves perfect AUC = 1.000 on both datasets. Inverted ECS alone achieves AUC = 0.809 on the splice benchmark and AUC = 0.807 on the boilerplate benchmark. Adding ECS to Jaccard yields no improvement ($\Delta $AUC $\approx $ 0) because Jaccard is already a perfect separator.}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:fig3}{{3}{7}{ROC-AUC on the near-duplicate vs.\ hard-negative hard subset (5-fold CV) for five classifier variants on both benchmarks. Jaccard (5-gram and 2-gram) achieves perfect AUC = 1.000 on both datasets. Inverted ECS alone achieves AUC = 0.809 on the splice benchmark and AUC = 0.807 on the boilerplate benchmark. Adding ECS to Jaccard yields no improvement ($\Delta $AUC $\approx $ 0) because Jaccard is already a perfect separator}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces 5-gram Jaccard ($J_5$) distributions by pair class on both benchmarks. On the splice benchmark (top), near-duplicate pairs have $J_5 \in [0.50, 0.75]$ (mean 0.58) while both negative classes have $J_5 \approx 0$, creating a perfect separation. On the boilerplate benchmark (bottom), the boilerplate hard-negative class shifts upward to $J_5 = 0.09$--$0.15$ (mean 0.089) due to the shared CC-BY-SA header, but still does not overlap with the near-duplicate range---explaining why Jaccard remains a perfect classifier on this benchmark.}}{8}{figure.4}\protected@file@percent }
\newlabel{fig:fig4}{{4}{8}{5-gram Jaccard ($J_5$) distributions by pair class on both benchmarks. On the splice benchmark (top), near-duplicate pairs have $J_5 \in [0.50, 0.75]$ (mean 0.58) while both negative classes have $J_5 \approx 0$, creating a perfect separation. On the boilerplate benchmark (bottom), the boilerplate hard-negative class shifts upward to $J_5 = 0.09$--$0.15$ (mean 0.089) due to the shared CC-BY-SA header, but still does not overlap with the near-duplicate range---explaining why Jaccard remains a perfect classifier on this benchmark}{figure.4}{}}
